<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('include/head', { title: 'Democracy Viewer', extraCSS: [] }) %>
  <style>
    .gradient-bg { background: linear-gradient(160deg, #fde8c0 0%, #e8d8f0 50%, #d8d0f0 100%); }
    nav { background: rgba(253,232,192,0.85); border-bottom: 1px solid rgba(200,170,100,0.15); justify-content: space-between; }
    .nav-links { position: static; transform: none; margin-left: auto; }

    .page-hero { padding: 9rem var(--side) 4rem; max-width: 1400px; margin: 0 auto; }
    .case-eyebrow { font-size: 0.68rem; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; color: var(--text-light); margin-bottom: 0.7rem; }
    .case-title { font-family: var(--serif); font-size: clamp(2.8rem, 6vw, 6rem); font-weight: 300; line-height: 0.95; color: var(--text-dark); margin-bottom: 1.5rem; }
    .case-subtitle { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-light); margin-bottom: 1.8rem; }
    .case-intro { font-family: var(--serif); font-size: clamp(1rem, 1.8vw, 1.25rem); font-style: italic; font-weight: 300; color: var(--text-mid); max-width: 620px; line-height: 1.7; margin-bottom: 2rem; }

    .case-body { padding: 0 var(--side) 6rem; max-width: 1400px; margin: 0 auto; }
    .gallery-divider { width: 100%; height: 1px; background: linear-gradient(90deg, transparent, rgba(200,170,100,0.3), transparent); margin-bottom: 4rem; }

    .case-section { margin-bottom: 5rem; }
    .section-header { display: grid; grid-template-columns: 1fr 1.8fr; gap: 4rem; align-items: start; margin-bottom: 2rem; }
    .section-meta { position: sticky; top: 6rem; }
    .section-number { font-size: 0.65rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-light); margin-bottom: 0.5rem; }
    .section-name { font-family: var(--serif); font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 300; color: var(--text-dark); line-height: 1.1; margin-bottom: 1rem; }
    .section-desc { font-size: 0.9rem; line-height: 1.8; color: var(--text-mid); }
    .section-desc + .section-desc { margin-top: 0.8rem; }

    .img-grid-1 { display: grid; grid-template-columns: 1fr; gap: var(--gap); }
    .img-grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap); }
    .img-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap); }

    .case-img { border-radius: 12px; overflow: hidden; cursor: zoom-in; transition: transform 0.35s cubic-bezier(0.23,1,0.32,1), box-shadow 0.35s ease; }
    .case-img:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(74,56,96,0.12); }
    .case-img img { width: 100%; display: block; border-radius: 12px; }
    .img-label { font-size: 0.7rem; color: var(--text-light); letter-spacing: 0.06em; margin-top: 0.4rem; font-style: italic; font-family: var(--serif); }

    .lightbox { display: none; position: fixed; inset: 0; z-index: 999; background: linear-gradient(160deg, rgba(253,232,192,0.55) 0%, rgba(232,216,240,0.55) 50%, rgba(216,208,240,0.55) 100%); backdrop-filter: blur(30px) saturate(1.2); -webkit-backdrop-filter: blur(30px) saturate(1.2); align-items: center; justify-content: center; flex-direction: column; padding: 2rem; cursor: zoom-out; }
    .lightbox.open { display: flex; animation: lbIn 0.25s ease; }
    @keyframes lbIn { from { opacity: 0; } to { opacity: 1; } }
    .lightbox-img-wrap { max-width: min(90vw, 1100px); max-height: 82vh; display: flex; align-items: center; justify-content: center; cursor: default; }
    .lightbox img { max-width: 100%; max-height: 80vh; border-radius: 12px; object-fit: contain; box-shadow: 0 8px 48px rgba(74,56,96,0.18); cursor: default; }
    .lightbox-close { position: absolute; top: 1.4rem; right: 1.6rem; font-size: 1.4rem; color: var(--text-mid); cursor: pointer; background: none; border: none; line-height: 1; transition: color 0.2s; z-index: 1000; }
    .lightbox-close:hover { color: var(--text-dark); }
    .lightbox-nav { position: absolute; top: 50%; transform: translateY(-50%); font-size: 1.4rem; color: var(--text-mid); background: none; border: none; cursor: pointer; padding: 1rem 1.2rem; transition: color 0.2s; z-index: 1000; }
    .lightbox-nav:hover { color: var(--text-dark); }
    .lightbox-prev { left: 0.5rem; } .lightbox-next { right: 0.5rem; }
    .lightbox-counter { position: absolute; top: 1.5rem; left: 50%; transform: translateX(-50%); font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-light); }
    .lightbox-caption { margin-top: 1rem; text-align: center; }
    .lightbox-caption p { font-family: var(--serif); font-style: italic; font-size: 1rem; color: var(--text-dark); }

    .case-nav { display: flex; justify-content: space-between; align-items: center; padding: 2rem var(--side) 3rem; max-width: 1400px; margin: 0 auto; }
    .case-nav a { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-mid); text-decoration: none; transition: color 0.2s, gap 0.2s; }
    .case-nav a:hover { color: var(--text-dark); gap: 0.8rem; }

    @media (max-width: 900px) {
      :root { --side: 1.2rem; }
      nav { padding: 1.1rem var(--side); }
      .section-header { grid-template-columns: 1fr; gap: 1.2rem; }
      .section-meta { position: static; }
      .img-grid-3 { grid-template-columns: repeat(2, 1fr); }
      .img-grid-2 { grid-template-columns: 1fr; }
      .lightbox-nav { display: none; }
    }
    @media (max-width: 560px) { .img-grid-3, .img-grid-2 { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
<div class="gradient-bg"></div>

<div class="lightbox" id="lightbox" onclick="closeLightbox(event)">
  <button class="lightbox-close" onclick="closeLightboxDirect()">&times;</button>
  <span class="lightbox-counter" id="lb-counter"></span>
  <button class="lightbox-nav lightbox-prev" onclick="event.stopPropagation();shiftLightbox(-1)">&#8592;</button>
  <div class="lightbox-img-wrap" onclick="event.stopPropagation()">
    <img id="lb-img" src="" alt="">
  </div>
  <button class="lightbox-nav lightbox-next" onclick="event.stopPropagation();shiftLightbox(1)">&#8594;</button>
  <div class="lightbox-caption" onclick="event.stopPropagation()"><p id="lb-title"></p></div>
</div>

<%- include('include/header-nav') %>

<div class="page-hero">
  <a href="/portfolio/uiux-design" class="back-link">&#8592; Back to UI/UX</a>
  <p class="case-eyebrow">Case Study 01 &mdash; UI/UX Design</p>
  <h1 class="case-title">Democracy<br>Viewer</h1>
  <p class="case-subtitle">UI/UX Redesign &middot; Front-End Development &middot; SMU &amp; Emory University</p>
  <p class="case-intro">Redesigning a data visualization platform to make complex humanities research more accessible and intuitive for all users, turning statistical methods into collaborative, interactive experiences. Some designs shown are high fidelity concepts created in Figma and are not yet fully implemented.</p>
  <div class="page-tags">
    <span class="tag">Figma</span>
    <span class="tag">UX Research</span>
    <span class="tag">Front-End Dev</span>
    <span class="tag">React</span>
  </div>
</div>

<div class="case-body">
  <div class="gallery-divider"></div>

  <div class="case-section">
    <div class="section-header">
      <div class="section-meta">
        <p class="section-number">01 &mdash; Home</p>
        <h2 class="section-name">Home Page</h2>
        <p class="section-desc">Democracy Viewer is an open access platform that makes text based data analytics more accessible across the humanities and social sciences, built by a multidisciplinary team at SMU and Emory University.</p>
        <p class="section-desc" style="margin-top:0.8rem;">The home page serves as a welcoming entry point, featuring a dynamic hero that highlights recent visualizations, clear feature cards for intuitive navigation, and a Featured Gallery that encourages exploration. I contributed to refining the layout, visual direction, brand identity, and overall user experience.</p>
      </div>
      <div class="img-grid-1">
        <div class="case-img" onclick="openLightbox(0)">
          <img src="/images/uiux/DV/DVhome.png" alt="Home Page">
          <p class="img-label">Home &mdash; full page view</p>
        </div>
      </div>
    </div>
  </div>

  <div class="case-section">
    <div class="section-header">
      <div class="section-meta">
        <p class="section-number">02 &mdash; Visualize</p>
        <h2 class="section-name">Visualizations</h2>
        <p class="section-desc">The Visualize page is the core of Democracy Viewer, where users configure data analysis through a settings panel and render interactive plots. I refined the experience to make navigation more intuitive and to better highlight the platform's graphing capabilities.</p>
        <p class="section-desc" style="margin-top:0.8rem;">Because the platform's features can feel overwhelming for new users, I designed a built in Guided Mode that overlays step by step instructions directly on the page. It can be easily toggled on or off, allowing both first time and experienced users to customize the level of guidance they need.</p>
      </div>
      <div class="img-grid-2">
        <div class="case-img" onclick="openLightbox(1)">
          <img src="/images/uiux/DV/DVvisual.png" alt="Visualize Page">
          <p class="img-label">Visualize &mdash; bar plot view</p>
        </div>
        <div class="case-img" onclick="openLightbox(2)">
          <img src="/images/uiux/DV/DVvisualTips.png" alt="Guided Mode">
          <p class="img-label">Visualize &mdash; Guided Mode on</p>
        </div>
      </div>
    </div>
  </div>

  <div class="case-section">
    <div class="section-header">
      <div class="section-meta">
        <p class="section-number">03 &mdash; Authentication &amp; Upload</p>
        <h2 class="section-name">Sign In &amp; Upload</h2>
        <p class="section-desc">A cohesive sign in and upload experience. The upload page features a simple authentication and upload flow that allows users to contribute datasets through CSV files or external API connections, supporting easy and accessible data sharing.</p>
      </div>
      <div class="img-grid-2">
        <div class="case-img" onclick="openLightbox(3)">
          <img src="/images/uiux/DV/DVsignin.png" alt="Sign In Page">
          <p class="img-label">Sign In page</p>
        </div>
        <div class="case-img" onclick="openLightbox(4)">
          <img src="/images/uiux/DV/DVupload.png" alt="Upload Dataset Page">
          <p class="img-label">Upload Dataset page</p>
        </div>
      </div>
    </div>
  </div>

  <div class="case-section">
    <div class="section-header">
      <div class="section-meta">
        <p class="section-number">04 &mdash; Search</p>
        <h2 class="section-name">Subsearch Datasets</h2>
        <p class="section-desc">The Subsearch Datasets page allows researchers to browse and filter the platform's growing library of text-based datasets. Users can search by keyword or open the Advanced Filter to narrow results by title, description, owner, privacy, or tags. My redesign refines the layout and filter interface to feel more intuitive, organized, and visually consistent with the rest of the platform.</p>
      </div>
      <div class="img-grid-1">
        <div class="case-img" onclick="openLightbox(5)">
          <img src="/images/uiux/DV/DVsubsearch.png" alt="Subsearch Datasets">
          <p class="img-label">Subsearch Datasets page</p>
        </div>
      </div>
    </div>
  </div>

  <div class="case-section">
    <div class="section-header">
      <div class="section-meta">
        <p class="section-number">05 &mdash; Acknowledgments &amp; Team</p>
        <h2 class="section-name">Meet the Team</h2>
        <p class="section-desc">The Acknowledgments page celebrates the diverse team of students, researchers, and collaborators who have contributed to Democracy Viewer. Clicking any team member opens an expanded profile modal with a photo, bio, and LinkedIn link, giving proper credit to the people behind the platform.</p>
      </div>
      <div class="img-grid-1">
        <div class="case-img" onclick="openLightbox(6)">
          <img src="/images/uiux/DV/DVack.png" alt="Acknowledgments & Team Page">
          <p class="img-label">Meet the Team &mdash; with profile modal open</p>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="case-nav">
  <a href="/portfolio/uiux-design">&#8592; All Projects</a>
  <a href="/portfolio/uiux-design/smart-scheduler" class="next">Smart Scheduler &#8594;</a>
</div>

<%- include('include/footer') %>

<script>
  const imgs = [
    { src:'/images/uiux/DV/DVhome.png',       title:'Home Page' },
    { src:'/images/uiux/DV/DVvisual.png',      title:'Visualize &mdash; Bar Plot' },
    { src:'/images/uiux/DV/DVvisualTips.png',  title:'Visualize &mdash; Guided Mode' },
    { src:'/images/uiux/DV/DVsignin.png',      title:'Sign In Page' },
    { src:'/images/uiux/DV/DVupload.png',      title:'Upload Dataset' },
    { src:'/images/uiux/DV/DVsubsearch.png',   title:'Subsearch Datasets' },
    { src:'/images/uiux/DV/DVack.png',         title:'Meet the Team' },
  ];
  let cur = 0;
  function openLightbox(i) { cur=i; updateLB(); document.getElementById('lightbox').classList.add('open'); document.body.style.overflow='hidden'; }
  function updateLB() { const p=imgs[cur]; document.getElementById('lb-img').src=p.src; document.getElementById('lb-title').innerHTML=p.title; document.getElementById('lb-counter').textContent=(cur+1)+' / '+imgs.length; }
  function shiftLightbox(d) { cur=(cur+d+imgs.length)%imgs.length; updateLB(); }
  function closeLightbox(e) { if(e.target===document.getElementById('lightbox')) closeLightboxDirect(); }
  function closeLightboxDirect() { document.getElementById('lightbox').classList.remove('open'); document.body.style.overflow=''; }
  document.addEventListener('keydown', e => { const lb=document.getElementById('lightbox'); if(!lb.classList.contains('open')) return; if(e.key==='Escape') closeLightboxDirect(); if(e.key==='ArrowRight') shiftLightbox(1); if(e.key==='ArrowLeft') shiftLightbox(-1); });
</script>
</body>
</html>
