<script>
  const bg = document.getElementById('gradientBg');
  window.addEventListener('scroll', () => {
    const p = Math.min(window.scrollY / (document.body.scrollHeight - window.innerHeight), 1);
    const r1 = Math.round(253-p*15), g1 = Math.round(240-p*25), b1 = Math.round(192-p*10);
    const r2 = Math.round(224-p*10), g2 = Math.round(213-p*10), b2 = Math.round(240+p*5);
    bg.style.background = 'linear-gradient(160deg,rgb('+r1+','+g1+','+b1+') 0%,#fde0d0 40%,rgb('+r2+','+g2+','+b2+') 100%)';
  });
  const obs = new IntersectionObserver(es => es.forEach(e => {
    if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); }
  }), {threshold:0.12});
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
